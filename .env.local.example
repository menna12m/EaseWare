# Medusa storefront API
NEXT_PUBLIC_MEDUSA_URL=http://localhost:9000
# Printed at the end of `npm run seed` in the Medusa backend. Required on every /store/* request.
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=

# Shared secret with the backend revalidate webhooks
REVALIDATE_SECRET=

# Strapi headless CMS (stories, FAQs, policies)
NEXT_PUBLIC_STRAPI_URL=http://localhost:1337

# Algolia — optional, swap medusaSearchClient back to algoliasearch when set
NEXT_PUBLIC_ALGOLIA_APP_ID=
NEXT_PUBLIC_ALGOLIA_SEARCH_KEY=

# Cloudinary — optional CDN for hero/persona imagery
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
