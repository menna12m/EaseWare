# Algolia — faceted search index
NEXT_PUBLIC_ALGOLIA_APP_ID=your_algolia_app_id
NEXT_PUBLIC_ALGOLIA_SEARCH_KEY=your_algolia_search_only_key

# Medusa storefront API
NEXT_PUBLIC_MEDUSA_URL=http://localhost:9000
# Printed at the end of `npm run seed` in the Medusa backend. Required on every /store/* request.
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=

# Server-only — must match the JWT_SECRET in EaseWareBackend/medusa/.env
# Used by /api/wishlist bridge to mint a Medusa-compatible customer JWT.
MEDUSA_JWT_SECRET=

# Server-only — shared with the Medusa/Strapi backend revalidate webhook
REVALIDATE_SECRET=

# Strapi headless CMS (stories, FAQs, policies)
NEXT_PUBLIC_STRAPI_URL=http://localhost:1337

# Cloudinary — product imagery
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=easewear

# Supabase — customer auth
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
